local function ExecuteParry()
    local camera = workspace.CurrentCamera
    local cameraCFrame = camera and camera.CFrame or CFrame.new()

    if CurrentMode == "upwards" or CurrentMode == "Up" then
        local look = cameraCFrame.LookVector
        local upDir = Vector3.new(look.X, 10, look.Z).Unit
        cameraCFrame = CFrame.new(cameraCFrame.Position, cameraCFrame.Position + upDir)
    elseif CurrentMode == "backwards" or CurrentMode == "Backward" then
        cameraCFrame = CFrame.lookAt(cameraCFrame.Position, cameraCFrame.Position - cameraCFrame.LookVector)
    elseif CurrentMode == "random" or CurrentMode == "Random" then
        local randomDir = Vector3.new(math.random(-1000,1000)*0.001, math.random(-350,1000)*0.001, math.random(-1000,1000)*0.001).Unit
        cameraCFrame = CFrame.new(cameraCFrame.Position, cameraCFrame.Position + randomDir)
    elseif CurrentMode == "Side" then
        local side = math.random(1,2) == 1 and 90 or -90
        cameraCFrame = cameraCFrame * CFrame.Angles(0, math.rad(side), 0)
    end

    if next(parryRemoteCache) then
        for remote, originalArgs in pairs(parryRemoteCache) do
            local modifiedArgs = {originalArgs[1], originalArgs[2], 0, cameraCFrame, originalArgs[5], originalArgs[6]}
            if remote:IsA("RemoteEvent") then
                remote:FireServer(unpack(modifiedArgs))
            elseif remote:IsA("RemoteFunction") then
                remote:InvokeServer(unpack(modifiedArgs))
            end
        end
    else
        VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end

    if Parry_Animation_API then
        pcall(function()
            if type(Parry_Animation_API) == "function" then Parry_Animation_API()
            elseif type(Parry_Animation_API) == "table" and Parry_Animation_API.Play then Parry_Animation_API:Play() end
        end)
    end
    return true
end

