local function addTrail(ball, color)
    if not ball:FindFirstChild("KittyTrail") then
        local att0 = Instance.new("Attachment", ball); att0.Name = "TrailAtt0"; att0.Position = Vector3.new(0, 1, 0)
        local att1 = Instance.new("Attachment", ball); att1.Name = "TrailAtt1"; att1.Position = Vector3.new(0, -1, 0)
        local trail = Instance.new("Trail", ball); trail.Name = "KittyTrail"
        trail.Attachment0 = att0; trail.Attachment1 = att1
        trail.Lifetime = 0.5; trail.MinLength = 0
        trail.Transparency = NumberSequence.new(0, 1); trail.LightEmission = 0.5
    end
    local t = ball:FindFirstChild("KittyTrail")
    if t and typeof(color) == "Color3" then t.Color = ColorSequence.new(color) end
end

local function removeTrail(ball)
    if ball:FindFirstChild("KittyTrail") then ball.KittyTrail:Destroy() end
    if ball:FindFirstChild("TrailAtt0") then ball.TrailAtt0:Destroy() end
    if ball:FindFirstChild("TrailAtt1") then ball.TrailAtt1:Destroy() end
end

local orbitParts = {}
local function setupOrbit()
    for _, v in pairs(orbitParts) do pcall(function() v:Destroy() end) end
    orbitParts = {}
    local orbitColors = {
        Color3.fromRGB(0, 255, 255), Color3.fromRGB(255, 0, 255),
        Color3.fromRGB(255, 255, 0), Color3.fromRGB(0, 255, 0),
    }
    for i = 1, 4 do
        local part = Instance.new("Part", workspace)
        part.Name = "KittyOrbit"
        part.Size = Vector3.new(0.5, 0.5, 0.5)
        part.Anchored = true
        part.CanCollide = false
        part.BrickColor = BrickColor.new(orbitColors[i])
        part.Material = Enum.Material.Neon
        part.CastShadow = false
        table.insert(orbitParts, part)
    end
end

